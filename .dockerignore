# Dependencies — reinstalled inside the container
node_modules/

# Build output — rebuilt inside the container
dist/
dist-ssr/

# Environment files — must be injected at build time via --build-arg, never baked into the image
.env
.env.*
!.env.example

# Version control
.git/
.gitignore

# Editor / OS artifacts
.vscode/
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local dev / tooling artifacts
.agents/
.tanstack/
docs/
